{
  "name": "@santeproche/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc",
    "start": "node dist/main.js",
    "lint": "eslint . --ext .ts",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "migrate:generate": "drizzle-kit generate",
    "migrate:run": "drizzle-kit migrate",
    "seed:facilities": "tsx src/seed/facilities.ts",
    "seed:drugs": "tsx src/seed/drugs.ts"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.30.0",
    "fastify": "^4.26.2",
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^8.0.0",
    "@fastify/multipart": "^8.2.0",
    "@fastify/rate-limit": "^9.0.1",
    "@fastify/websocket": "^8.3.1",
    "ioredis": "^5.3.2",
    "minio": "^7.1.3",
    "pg": "^8.11.3",
    "pino": "^8.19.0",
    "pino-pretty": "^11.0.0",
    "ws": "^8.16.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.11.30",
    "@types/pg": "^8.11.4",
    "@types/ws": "^8.5.10",
    "drizzle-kit": "^0.20.14",
    "eslint": "^8.57.0",
    "tsx": "^4.7.2",
    "typescript": "^5.4.3",
    "vitest": "^1.4.0"
  }
}